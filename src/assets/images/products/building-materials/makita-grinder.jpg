}

#megamenu-1328 #megamenu-tab-581451 .tab-item.active{
	height:calc(100% + 1px);
	background:#fff;
	border-bottom:solid 1px #fff!important;
}
#megamenu-1328 #megamenu-tab-581451 .tab-item.active .txt, #megamenu-1328 #megamenu-tab-581451 .tab-item.active .arrow svg{
	color:red!important;
