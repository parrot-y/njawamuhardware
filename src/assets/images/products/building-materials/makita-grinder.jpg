    <script>
        document.addEventListener("DOMContentLoaded", function() {
            function adjustIframeHeight(iframeId) {
                var iframe = document.getElementById(iframeId);

                if (iframe) {
                    iframe.addEventListener('load', function() {
                        this.style.height = this.contentWindow.document.body.scrollHeight + 55 + 'px';

                        iframeDocument.body.style.margin = '0';
                        iframeDocument.body.style.padding = '0';
                        iframeDocument.body.style.overflow = 'hidden';
                        iframeDocument.documentElement.style.overflow = 'hidden';
                    });
                }
            }

            adjustIframeHeight('leaflets');
            adjustIframeHeight('catalogues');
        });
    </script>
