#megamenu-1328 .megamenu-tab.small .tabset {
    width: 100%;
    position: absolute;
    top: 0;
    left: 0;
    height: 42px;
    z-index: 999;
    padding: 0px!important;
	background:#eaeaea;
}

#megamenu-1328 #megamenu-tab-581451 .tab-item {
    color: #ffffff;
    font-size: 15px;
    font-weight: 500;
    text-transform: none;
    float: left;
    width: 20%;
		padding-top:10px;
	background:#eaeaea;
	height:100%;
