/* Improved footer spacing on mobile (keeps left alignment) */
@media (max-width: 767px) {
  .site-footer .footer-widgets .widget {
    padding-left: 12px;
    padding-right: 12px;
    margin-bottom: 22px;
  }

  .site-footer .footer-widgets .widget-title {
    margin-bottom: 10px;
  }

  .site-footer .footer-widgets li,
  .site-footer .footer-widgets p,
  .site-footer .footer-widgets a {
    line-height: 1.6;
  }
}
/* Extra footer spacing improvement */
.site-footer-bottom,
.footer-bottom {
    padding-top: 14px;
    padding-bottom: 14px;
}

/* Mobile-specific tuning */
@media (max-width: 767px) {
  .site-footer-bottom,
  .footer-bottom {
      padding-top: 18px;
      padding-bottom: 18px;
      text-align: left; /* keeps it neat and professional */
      padding-left: 12px;
      padding-right: 12px;
  }
}

/* Mobile left padding adjustment - Jemspark */
@media only screen and (max-width: 767px) {
  .site-content,
  body,
  .container,
  .elementor-section,
  .elementor-container,
  .elementor-widget-wrap {
    padding-left: 2px !important;
    padding-right: 2px !important;
  }
}

/* JEMSPARK - Make Home Slider & Banner Full Width on Mobile */
@media only screen and (max-width: 767px) {

  /* Remove container padding for slider + banner */
  .elementor-section.elementor-section-full_width,
  .elementor-section[data-element_type="section"] {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Ensure the internal container stretches fully */
  .elementor-section .elementor-container {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Force images inside slider & banners to go edge-to-edge */
  .elementor-widget-image img,
  .elementor-widget-slides .slick-slide img,
  .elementor-slide-background,
  .elementor-image-carousel-wrapper img {
    width: 100% !important;
    height: auto !important;
    display: block !important;
  }
}

/* Refined fix for "Download App on Mobile" section */
@media only screen and (max-width: 768px) {
  .mobile-app-content {
    margin-bottom: 100px !important; /* keeps space above bottom bar */
    position: static !important; /* normal flow, not floating */
    z-index: auto !important; /* removes overlay effect */
  }
}

.woocommerce-Tabs-panel h2,
.product .product-details h2,
.woocommerce-product-details__short-description h2 {
    display: block !important;
    font-size: 20px !important;
    margin: 20px 0 10px !important;
    font-weight: 600 !important;
}

