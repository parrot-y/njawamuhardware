		<style type="text/css" id="wp-custom-css">
			@media only screen and (max-width: 767px) {
    /* Main container for products/grid */
    .products, 
    .wc-block-grid__products {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 4px;
		 
    }
    
    /* Individual product items */
    .product, 
    .wc-block-grid__product {
        width: 100% !important;
        margin: 0 !important;
        float: none !important;
    }
    
    /* Product images */
    .attachment-woocommerce_thumbnail, 
    .wc-block-grid__product-image {
        width: 100%;
        height: auto;
    }
    
    /* Adjust spacing */
    .product .woocommerce-loop-product__title,
    .wc-block-grid__product-title {
        font-size: 14px;
        margin: 4px 0;
        min-height: 40px; /* For consistent title alignment */
    }
    
    .price {
        font-size: 14px;
        margin: 4px 0;
    }
    
    /* Buttons */
    .add_to_cart_button, 
    .ajax_add_to_cart,
    .wc-block-grid__product-add-to-cart {
        width: 100%;
        padding: 8px 4px;
        font-size: 12px;
    }
    
    /* Fix any potential overflow */
    .woocommerce-loop-product__link,
    .wc-block-grid__product-link {
        display: block;
        overflow: hidden;
    }
}
/* reduce the sale price font size */
 
.archive span.price del {
margin-right: -10px;
font-size: 10px !important;
}

/* Mobile Optimization for 2-Column Grid */
@media (max-width: 767px) {
  /* Align product container with header/footer padding */
  .container, 
  .woocommerce ul.products {
    padding-left: 0px !important;  /* Match header/footer padding */
    padding-right:  0px !important;
    margin: 0 auto !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
}
  /* Force 2-column grid with consistent spacing */
  .woocommerce ul.products li.product {
    width: calc(50% - 8px) !important;  /* 2 columns with 8px gap */
    margin-right: 8px !important;
    margin-bottom: 16px !important;
    float: left !important;
    padding: 0 !important;  /* Remove inner padding if any */
  }

  /* Clear margin on every 2nd item */
  .woocommerce ul.products li.product:nth-child(2n) {
    margin-right: 0 !important;
  }

  /* Ensure product content (title/price) stays aligned */
  .woocommerce-loop-product__title,
  .price {
    text-align: left !important;
    font-size: 14px !important;  /* Optional: Adjust font size */
    margin: 10px 0 !important;    /* Reduce spacing */
  }

  /* Fix image overflow */
  .woocommerce ul.products li.product a img {
    width: 100% !important;
    height: auto !important;
    border-radius: 4px !important;  /* Optional: Match design */
  }

/* 1. BLOCK HORIZONTAL SCROLL AT ROOT LEVEL */
html, body {
  overflow-x: hidden !important;
  width: 100% !important;
  max-width: 100% !important;
}
/* Mobile Optimization - Prevent Horizontal Scroll */
@media (max-width: 768px) {
  /* Reset body/container overflow */
  body, 
  .page-wrapper,
  .container {
    overflow-x: hidden !important; /* Blocks horizontal scroll */
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 0px !important; /* Match header/footer padding */
    box-sizing: border-box !important;
  }
}
/* Optimize images and interactions for speed */  
@media (max-width: 767px) {  
    .woocommerce-loop-product__link img,  
    .wc-block-grid__product-image img {  
        aspect-ratio: 1/1; /* Force square images (adjust ratio if needed) */  
        object-fit: cover; /* Prevent stretched images */  
        loading: lazy; /* Native lazy load */  
    }  

    /* Remove unnecessary animations */  
    .product, .add_to_cart_button {  
        transition: none !important;  
    }  

    /* Minimize layout shifts */  
    .price {  
        min-height: 20px; /* Reserve space for price to avoid jumps */  
    }  
}  
	 /* Text/content adjustments */
  .woocommerce-loop-product__title,
  .price {
    font-size: 12px !important;  /* Adjust as needed */
    margin: 14px 0 !important;    /* Consistent spacing */
    white-space: normal !important;  /* Prevents text clipping */
  }
}

/* WhatsApp Button Styling */
.whatsapp-order-button {
    background: #25D366 !important;
    color: white !important;
    border: none !important;
    padding: 10px 15px !important;
    font-weight: bold !important;
    border-radius: 4px !important;
    text-align: center !important;
    display: inline-block !important;
}
.whatsapp-order-button:hover {
    background: #128C7E !important;
}

